# ==========================================================================
# .env.local.example
# ==========================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored (never committed).
# For Vercel production, add the same vars in:
#   Vercel Dashboard → Settings → Environment Variables
# ==========================================================================

# --- Brevo (formerly Sendinblue) -----------------------------------------
# 1) Generate API key:
#    Brevo → Settings (gear icon) → SMTP & API → API Keys
#    Click "Generate new API key" → name it "knowing-more site" → copy.
#    Use the v3 API key (`xkeysib-...`) for /v3/contacts.
#    The SMTP key (`xsmtpsib-...`) is meant for transactional sending and
#    may not work for /v3/contacts on some Brevo plans.
BREVO_API_KEY=xkeysib-REPLACE-ME

# 2) Get list IDs:
#    Brevo → Contacts → Lists → click a list → check the "ID" column or URL.
#    Set BREVO_LIST_ID_DEFAULT (required). Source-specific ones are optional;
#    if empty the route falls back to BREVO_LIST_ID_DEFAULT.
BREVO_LIST_ID_DEFAULT=

# Optional per-source lists (leave blank to use DEFAULT).
BREVO_LIST_ID_DISCOUNT=
BREVO_LIST_ID_NEWSLETTER=
BREVO_LIST_ID_PRODUCT_PERFORMANCE=
BREVO_LIST_ID_PRODUCT_BALANCE=
BREVO_LIST_ID_PRODUCT_GUT_HEALTH=
BREVO_LIST_ID_BUNDLE=
